# ============================================================
# MengASR2 配置文件模板
# ============================================================
# 复制为 mengasr.yaml 并根据实际环境修改：
#   cp config/mengasr.yaml.example config/mengasr.yaml
#
# 优先级：环境变量 > mengasr.yaml > 代码默认值
#
# 切换后端只需改 worker.backend，重启 Worker 即可：
#   worker.backend: mimo        → MiMo-V2.5-ASR (7.5B)
#   worker.backend: qwen3-asr   → Qwen3-ASR-1.7B
# ============================================================

# ── Worker 进程配置（模型推理） ──────────────────────────
worker:
  # 后端选择：mimo | qwen3-asr（改这里即可切换模型）
  backend: mimo

  # 监听地址（仅 localhost，不对公网暴露）
  host: 127.0.0.1
  port: 8789

  # MiMo 后端路径（请根据实际部署路径修改）
  mimo_model_path: /srv/mengasr/models/XiaomiMiMo/MiMo-V2.5-ASR
  mimo_tokenizer_path: /srv/mengasr/models/XiaomiMiMo/MiMo-Audio-Tokenizer
  mimo_code_path: /srv/mengasr/MiMo-V2.5-ASR-code

  # Qwen3-ASR 后端（启用时设置 backend: qwen3-asr）
  # 可使用 HuggingFace model ID（自动下载）或本地路径
  qwen3_model_id: Qwen/Qwen3-ASR-1.7B

# ── Listener 进程配置（对外 HTTP 网关） ──────────────────
listener:
  # 对外监听（0.0.0.0 允许外部访问，建议配合鉴权或防火墙使用）
  host: "0.0.0.0"
  port: 8787
  max_upload_mb: 2000
  tmp_dir: /tmp/mengasr

# ── 鉴权 ─────────────────────────────────────────────────
auth:
  # Bearer Token（空 = 不鉴权，建议在可信内网中使用）
  # 生产环境建议设置一个强密码
  api_key: ""

# ── 异步任务队列 ─────────────────────────────────────────
jobs:
  ttl_hours: 24       # 已完成任务保留时间
  max_queue: 20        # 最大排队任务数

# ── 说话人分离 ───────────────────────────────────────────
diarization:
  # HuggingFace Token（说话人分离需要，留空则禁用）
  # 创建 Token: https://huggingface.co/settings/tokens
  # 需接受 pyannote/speaker-diarization-3.1 的使用条款
  hf_token: ""
  # HuggingFace 镜像（无法直连 huggingface.co 时使用）
  # 中国大陆用户可设置为: https://hf-mirror.com
  hf_endpoint: "https://huggingface.co"

# ── FFmpeg 路径 ──────────────────────────────────────────
ffmpeg:
  bin: ffmpeg
  ffprobe: ffprobe
